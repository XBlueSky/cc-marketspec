{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "MAJOR.MINOR of the standard this manifest was generated against."
    },
    "marketplace": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        },
        "owner": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "label"
        ],
        "additionalProperties": false
      },
      "description": "Group taxonomy in display order."
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Directory name = canonical id (== plugin.json name == marketplace.json entry name)."
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "Native plugin description."
          },
          "author": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          },
          "license": {
            "type": "string"
          },
          "homepage": {
            "type": "string"
          },
          "repository": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Native plugin dependencies (ids)."
          },
          "category": {
            "type": "string",
            "description": "Native classification, derived from marketplace.json entry."
          },
          "group": {
            "type": "string"
          },
          "tagline": {
            "type": "string"
          },
          "intro": {
            "type": "string"
          },
          "ccVersion": {
            "type": "string",
            "description": "Resolved = max(self, all deps)."
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "trigger": {
                  "type": "string"
                },
                "examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "href": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "autoload": {
                  "type": "boolean",
                  "description": "Derived from native user-invocable: false."
                },
                "resources": {
                  "type": "object",
                  "properties": {
                    "scripts": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "references": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "assets": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": [
                "name",
                "autoload"
              ],
              "additionalProperties": false
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "summary": {
                  "type": "string",
                  "description": "Derived: first sentence of native description."
                },
                "description": {
                  "type": "string"
                },
                "arguments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "required": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": false
                  },
                  "description": "Derived from native arguments / argument-hint."
                },
                "examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            }
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "returns": {
                  "type": "string"
                },
                "not": {
                  "type": "string"
                },
                "tools": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Derived from native frontmatter tools."
                },
                "examples": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            }
          },
          "mcp": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "stdio",
                    "http",
                    "sse",
                    "ws"
                  ],
                  "description": "Derived from .mcp.json."
                },
                "install": {
                  "type": "boolean"
                },
                "auth": {
                  "type": "string",
                  "enum": [
                    "none",
                    "token",
                    "oauth"
                  ]
                },
                "repo": {
                  "type": "string"
                },
                "env": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "secret": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "key"
                    ],
                    "additionalProperties": false
                  }
                },
                "setup": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string"
                      },
                      "cmd": {
                        "type": "string"
                      },
                      "href": {
                        "type": "string"
                      },
                      "label": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "text"
                    ],
                    "additionalProperties": false
                  }
                },
                "description": {
                  "type": "string"
                },
                "provides": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Authored, best-effort (not statically validated)."
                },
                "config": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "key",
                      "value"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false
            }
          },
          "hooks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event": {
                  "type": "string",
                  "enum": [
                    "PreToolUse",
                    "PostToolUse",
                    "PostToolUseFailure",
                    "PermissionRequest",
                    "UserPromptSubmit",
                    "Notification",
                    "Stop",
                    "SubagentStart",
                    "SubagentStop",
                    "SessionStart",
                    "SessionEnd",
                    "PreCompact"
                  ]
                },
                "matcher": {
                  "type": "string"
                },
                "why": {
                  "type": "string"
                }
              },
              "required": [
                "event"
              ],
              "additionalProperties": false
            }
          },
          "configuration": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "boolean",
                    "number",
                    "array"
                  ]
                },
                "default": {},
                "description": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean"
                }
              },
              "required": [
                "key",
                "type",
                "description"
              ],
              "additionalProperties": false
            }
          },
          "tips": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "href": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "text"
              ],
              "additionalProperties": false
            }
          },
          "traps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "href": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "text"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "name",
          "version"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "marketplace",
    "plugins"
  ],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/XBlueSky/cc-marketspec/main/schemas/manifest.schema.json",
  "title": "Marketplace manifest (generated consumer API)"
}
