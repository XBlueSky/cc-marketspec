---
// The native-vs-presentation mental model, drawn as a two-layer diagram.
// Content mirrors the README "native layer vs presentation layer" section.
const native = ['plugin.json', 'marketplace.json', '.mcp.json', 'SKILL.md', 'commands/*.md', 'hooks.json'];
const presentation = ['catalog.yaml', 'entry.yaml'];
---
<section id="mental-model" class="section">
  <div class="wrap">
    <span class="eyebrow">The mental model</span>
    <h2 class="mm-h2">Native facts, plus a presentation overlay.</h2>
    <p class="mm-lede">Claude Code already defines identity and structure. cc-marketspec
      adds only what native can't express — and the rule is strict:
      <strong>presentation never restates native facts.</strong> The generator joins
      the two by plugin id.</p>
    <div class="mm-diagram reveal">
      <div class="mm-layer">
        <h3 class="mm-title">Native <span>— Claude Code defines · you maintain anyway</span></h3>
        <ul class="mm-tokens">{native.map((f) => <li><code>{f}</code></li>)}</ul>
      </div>
      <div class="mm-layer mm-pres">
        <h3 class="mm-title">Presentation <span>— this standard · only the gaps</span></h3>
        <ul class="mm-tokens">{presentation.map((f) => <li><code>{f}</code></li>)}</ul>
      </div>
      <div class="mm-out"><span class="mm-arrow" aria-hidden="true">→</span>
        <code class="mm-manifest">manifest.json</code>
        <p>one render-agnostic document</p>
      </div>
    </div>
  </div>
</section>
<style>
  .mm-h2 { font-size:clamp(1.8rem,4vw,2.6rem); margin:1rem 0 .8rem; }
  .mm-lede { color:var(--muted); max-width:60ch; margin:0 0 2.2rem; }
  .mm-lede strong { color:var(--fg); }
  .mm-diagram { display:grid; grid-template-columns:1fr 1fr auto; gap:1.2rem; align-items:stretch; }
  .mm-layer { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1.4rem; }
  .mm-pres { border-color:var(--accent-soft); }
  .mm-title { font-family:var(--sans); font-weight:600; font-size:.95rem; letter-spacing:0; margin-bottom:.9rem; }
  .mm-title span { color:var(--muted); font-weight:400; font-size:.82rem; }
  .mm-tokens { list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:.4rem; }
  .mm-tokens code { font-family:var(--mono); font-size:.75rem; background:var(--code-chip);
    border-radius:5px; padding:.25rem .55rem; color:var(--fg); }
  .mm-pres .mm-tokens code { color:var(--accent); }
  .mm-out { display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; min-width:150px; }
  .mm-arrow { font-size:1.6rem; color:var(--muted); }
  .mm-manifest { font-family:var(--mono); font-size:.9rem; color:var(--accent); font-weight:500; margin:.4rem 0 .2rem; }
  .mm-out p { color:var(--muted); font-size:.78rem; margin:0; }
  @media (max-width:820px){ .mm-diagram { grid-template-columns:1fr; } .mm-arrow { transform:rotate(90deg); } }
</style>
