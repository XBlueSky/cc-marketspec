---
// The native-vs-presentation mental model, drawn as a two-layer diagram.
// Content mirrors the README "native layer vs presentation layer" section.
const native = ['marketplace.json', 'plugin.json', '.mcp.json', 'skills/*/SKILL.md', 'commands/*.md', 'agents/*.md', 'hooks/hooks.json'];
const presentation = ['catalog.yaml', 'entry.yaml'];
---
<section id="mental-model" class="section">
  <div class="wrap">
    <span class="sec-num">02</span>
    <span class="eyebrow">The mental model</span>
    <h2 class="mm-h2">Native facts, plus a presentation overlay.</h2>
    <p class="mm-lede">Claude Code already defines identity and structure. cc-marketspec
      adds only what native can't express — and the rule is strict:
      <strong>presentation never restates native facts.</strong> The generator joins
      the two by plugin id.</p>
    <div class="mm-diagram reveal">
      <div class="mm-layer">
        <h3 class="mm-title">Native <span>— Claude Code defines · you maintain anyway</span></h3>
        <ul class="mm-tokens">{native.map((f) => <li><code>{f}</code></li>)}</ul>
      </div>
      <div class="mm-layer mm-pres">
        <h3 class="mm-title">Presentation <span>— this standard · only the gaps</span></h3>
        <ul class="mm-tokens">{presentation.map((f) => <li><code>{f}</code></li>)}</ul>
      </div>
      <div class="mm-out"><span class="mm-arrow" aria-hidden="true">→</span>
        <code class="mm-manifest">manifest.json</code>
        <p>one render-agnostic document</p>
      </div>
    </div>
    <div class="mm-code-section reveal">
      <div class="mm-code-row">
        <figure class="mm-code-panel reveal" style="--i:0">
          <figcaption>plugin.json & .mcp.json</figcaption>
          <pre><code><span class="c">// plugin.json</span>
<span class="p">{</span> <span class="k">"name"</span><span class="p">:</span> <span class="s">"cc-marketspec"</span><span class="p">,</span> <span class="k">"version"</span><span class="p">:</span> <span class="s">"0.2.0"</span><span class="p">,</span> <span class="k">"license"</span><span class="p">:</span> <span class="s">"MIT"</span><span class="p">,</span> <span class="c">…</span> <span class="p">}</span>
<span class="c">// .mcp.json</span>
<span class="p">{</span> <span class="k">"mcpServers"</span><span class="p">:</span> <span class="p">{</span> <span class="k">"cc-marketspec"</span><span class="p">:</span> <span class="p">{</span> <span class="k">"type"</span><span class="p">:</span> <span class="s">"http"</span><span class="p">,</span> <span class="c">…</span> <span class="p">}</span> <span class="p">}</span> <span class="p">}</span></code></pre>
        </figure>
        <figure class="mm-code-panel reveal" style="--i:1">
          <figcaption>entry.yaml</figcaption>
          <pre><code><span class="c"># entry.yaml</span>
<span class="k">group</span><span class="p">:</span> <span class="s">tools</span>
<span class="k">tagline</span><span class="p">:</span> <span class="s">Headless data standard + generator …</span></code></pre>
        </figure>
      </div>
      <p class="mm-code-arrow" aria-hidden="true">↓ generated ↓</p>
      <figure class="mm-code-panel mm-code-full reveal" style="--i:2">
        <figcaption>manifest.json</figcaption>
        <pre><code><span class="p">{</span> <span class="k">"name"</span><span class="p">:</span> <span class="s">"cc-marketspec"</span><span class="p">,</span> <span class="k">"version"</span><span class="p">:</span> <span class="s">"0.2.0"</span><span class="p">,</span>
  <span class="k">"license"</span><span class="p">:</span> <span class="s">"MIT"</span><span class="p">,</span> <span class="k">"group"</span><span class="p">:</span> <span class="s">"tools"</span><span class="p">,</span>
  <span class="c">…</span><span class="p">,</span>
  <span class="k">"mcp"</span><span class="p">:</span> <span class="p">[{</span> <span class="k">"type"</span><span class="p">:</span> <span class="s">"http"</span><span class="p">,</span> <span class="k">"provides"</span><span class="p">:</span> <span class="p">[</span> <span class="c">…</span> <span class="p">]</span> <span class="p">}]</span> <span class="p">}</span></code></pre>
      </figure>
    </div>
  </div>
</section>
<style>
  .mm-h2 { font-size:clamp(1.8rem,4vw,2.6rem); margin:1rem 0 .8rem; }
  .mm-lede { color:var(--muted); max-width:60ch; margin:0 0 2.2rem; }
  .mm-lede strong { color:var(--fg); }
  .mm-diagram { display:grid; grid-template-columns:1fr 1fr auto; gap:1.2rem; align-items:stretch; }
  .mm-layer { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1.4rem; }
  .mm-pres { border-color:var(--accent-soft); }
  .mm-title { font-family:var(--sans); font-weight:600; font-size:.95rem; letter-spacing:0; margin-bottom:.9rem; }
  .mm-title span { color:var(--muted); font-weight:400; font-size:.82rem; }
  .mm-tokens { list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:.4rem; }
  .mm-tokens code { font-family:var(--mono); font-size:.75rem; background:var(--code-chip);
    border-radius:5px; padding:.25rem .55rem; color:var(--fg); }
  .mm-pres .mm-tokens code { color:var(--accent); }
  .mm-out { display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; min-width:150px; }
  .mm-arrow { font-size:1.6rem; color:var(--muted); }
  .mm-manifest { font-family:var(--mono); font-size:.9rem; color:var(--accent); font-weight:500; margin:.4rem 0 .2rem; }
  .mm-out p { color:var(--muted); font-size:.78rem; margin:0; }
  .mm-code-section { margin:1.8rem 0 0; display:flex; flex-direction:column; }
  .mm-code-row { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; }
  .mm-code-panel { margin:0; background:var(--surface); border:1px solid var(--border); border-radius:10px; overflow:hidden; min-width:0; }
  .mm-code-panel figcaption { font-family:var(--mono); font-size:.7rem; color:var(--muted); background:var(--code-chip); padding:.5rem .8rem; border-bottom:1px solid var(--border); }
  .mm-code-panel pre { margin:0; padding:.6rem .8rem; overflow-x:auto; }
  .mm-code-panel code { font-family:var(--mono); font-size:.7rem; line-height:1.6; }
  .mm-code-full { grid-column:1 / -1; }
  .mm-code-arrow { text-align:center; font-family:var(--mono); font-size:.7rem; color:var(--muted); margin:.9rem 0; }
  .k{color:var(--accent);} .s{color:var(--syntax-string);} .c{color:var(--syntax-comment);} .p{color:var(--syntax-punct);}
  @media (max-width:820px){ .mm-diagram { grid-template-columns:1fr; } .mm-arrow { transform:rotate(90deg); } .mm-code-row { grid-template-columns:1fr; } }
</style>
