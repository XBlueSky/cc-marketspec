---
interface Props {
	plugin: {
		id: string;
		name: string;
		version?: string;
		tagline?: string;
		intro?: string;
		description?: string;
		keywords?: string[];
		group?: string;
	};
}
const { plugin } = Astro.props;
---
<article class="card">
	<h2>{plugin.name} <span class="version">{plugin.version}</span></h2>
	{plugin.tagline && <p class="tagline">{plugin.tagline}</p>}
	{(plugin.intro ?? plugin.description) && <p class="intro">{plugin.intro ?? plugin.description}</p>}
	{plugin.keywords && plugin.keywords.length > 0 && (
		<div class="keywords">
			{plugin.keywords.map((k) => <span>{k}</span>)}
		</div>
	)}
	<slot />
</article>
<style>
  .card { background:var(--surface); border:1px solid var(--border); border-radius:12px;
    padding:1.6rem; margin:1.4rem 0; }
  .card h2 { font-family:var(--serif); font-weight:500; font-size:1.5rem; margin:0 0 .2rem; }
  .card .version { color:var(--muted); font-size:.8rem; font-family:var(--mono); }
  .card .tagline { color:var(--fg); font-size:1.05rem; margin:.4rem 0; }
  .card .intro { color:var(--muted); margin:.4rem 0 1rem; }
  .keywords { display:flex; flex-wrap:wrap; gap:.4rem; margin:.5rem 0; }
  .keywords span { background:var(--code-chip); border:1px solid var(--border);
    border-radius:999px; padding:.15rem .6rem; font-size:.78rem; color:var(--muted); }
</style>
