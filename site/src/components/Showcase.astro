---
import PluginCard from './PluginCard.astro';
import ComponentList from './ComponentList.astro';
import TipsTraps from './TipsTraps.astro';
import manifest from '../../../manifest.json';
type AnyItem = { name:string; trigger?:string; summary?:string; description?:string; provides?:string[] };
type SkillItem = AnyItem & { resources?: { scripts?:number; references?:number; assets?:number } };
const line = (it: AnyItem) => it.trigger ?? it.summary ?? it.description;
const skillMeta = (s: SkillItem): string | undefined => {
  if (!s.resources) return undefined;
  const parts: string[] = [];
  if (s.resources.references) parts.push(`${s.resources.references} ref`);
  if (s.resources.assets) parts.push(`${s.resources.assets} assets`);
  if (s.resources.scripts) parts.push(`${s.resources.scripts} scripts`);
  return parts.length > 0 ? parts.join(' · ') : undefined;
};
---
<section id="showcase" class="section showcase">
  <div class="wrap">
    <span class="sec-num">05</span>
    <span class="eyebrow">This section is the product</span>
    <h2 class="sc-h2">Rendered from this repo's manifest.json.</h2>
    <p class="sc-lede">The framework dogfoods itself.
      <a href="https://github.com/XBlueSky/cc-marketspec/blob/main/site/src/components/Showcase.astro">View source →</a></p>
    {manifest.plugins.map((plugin) => (
      <PluginCard plugin={plugin}>
        <ComponentList title="Skills" items={(plugin.skills ?? []).map((s) => ({ name:s.name, line:line(s), meta:skillMeta(s) }))} />
        <ComponentList title="Commands" items={(plugin.commands ?? []).map((c) => ({ name:c.name, line:line(c) }))} />
        <ComponentList title="Agents" items={(plugin.agents ?? []).map((a) => ({ name:a.name, line:line(a) }))} />
        <ComponentList title="MCP" items={(plugin.mcp ?? []).map((m) => ({ name:m.name, line:m.description, sub:m.provides }))} />
        <TipsTraps tips={plugin.tips} traps={plugin.traps} />
      </PluginCard>
    ))}
  </div>
</section>
<style>
  .sc-h2 { font-size:clamp(1.8rem,4vw,2.6rem); margin:1rem 0 .6rem; }
  .sc-lede { color:var(--muted); max-width:60ch; margin:0 0 2rem; }
</style>
