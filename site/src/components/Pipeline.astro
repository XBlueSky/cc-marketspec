---
// How it works: three steps as a horizontal flow with rhythm (not a 3-col grid).
const steps = [
  { n:'01', k:'Describe', d:'Write a little YAML — catalog.yaml at the root, entry.yaml per plugin. Only what native manifests can\'t express.', code:'schemaVersion: "1.0"\ngroups:\n  - id: tools\n    label: Tools' },
  { n:'02', k:'Generate', d:'The generator joins your YAML with native plugin manifests, checks referential integrity, and runs the coverage gate.', code:'$ npx @xbluesky/cc-marketspec\n✓ wrote manifest.json (1 plugin)' },
  { n:'03', k:'manifest.json', d:'One render-agnostic document any website can be built from. Commit it, or emit it as a CI artifact.', code:'{ "schemaVersion": "1.0",\n  "marketplace": { "name": "cc-marketspec" },\n  "plugins": [ … ] }' },
];
---
<section id="how" class="section how">
  <div class="wrap">
    <span class="sec-num">03</span>
    <span class="eyebrow">How it works</span>
    <h2 class="how-h2">Three steps, no design decisions.</h2>
    <ol class="how-flow">
      {steps.map((s, i) => (
        <li class="how-step reveal" style={`--i:${i}`}>
          <span class="how-n">{s.n}</span>
          <h3 class="how-k">{s.k}</h3>
          <p class="how-d">{s.d}</p>
          <pre class="how-code"><code>{s.code}</code></pre>
        </li>
      ))}
    </ol>
  </div>
</section>
<style>
  .how-h2 { font-size:clamp(1.8rem,4vw,2.6rem); margin:1rem 0 2rem; }
  .how-flow { list-style:none; padding:0; margin:0; display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; }
  .how-step { position:relative; padding-top:1rem; border-top:2px solid var(--accent); transition-delay:calc(var(--i) * 90ms); min-width:0; }
  .how-n { font-family:var(--mono); font-size:.8rem; color:var(--accent); }
  .how-k { font-size:1.3rem; margin:.3rem 0 .5rem; }
  .how-d { color:var(--muted); font-size:.92rem; margin:0 0 1rem; }
  .how-code { margin:0; background:var(--surface); border:1px solid var(--border);
    border-radius:8px; padding:.7rem .9rem; overflow-x:auto; }
  .how-code code { font-family:var(--mono); font-size:.74rem; color:var(--fg); white-space:pre; }
  @media (max-width:820px){ .how-flow { grid-template-columns:1fr; } }
</style>
