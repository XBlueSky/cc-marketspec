---
interface Item {
	name: string;
	line?: string;
	sub?: string[];
	meta?: string;
}
interface Props {
	title: string;
	items: Item[];
}
const { title, items } = Astro.props;
---
{items.length > 0 && (
	<section class="complist">
		<h3>{title}</h3>
		<ul>
			{items.map((item) => (
				<li>
					<code>{item.name}</code>
					{item.line && <span class="line"> — {item.line}</span>}
					{item.meta && <span class="meta">{item.meta}</span>}
					{item.sub && item.sub.length > 0 && (
						<span class="sub">{item.sub.map((s) => <code>{s}</code>)}</span>
					)}
				</li>
			))}
		</ul>
	</section>
)}
<style>
  .complist h3 { font-size:.8rem; text-transform:uppercase; letter-spacing:.05em;
    color:var(--muted); font-family:var(--mono); margin:1.2rem 0 .5rem; }
  .complist ul { list-style:none; padding:0; margin:0; }
  .complist li { padding:.4rem 0; border-top:1px solid var(--border); }
  .complist code { background:var(--code-chip); border-radius:4px; padding:.1rem .35rem;
    font-size:.85rem; color:var(--accent-ink); font-family:var(--mono); }
  .complist .line { color:var(--muted); }
  .complist .meta { font-family:var(--mono); font-size:.72rem; color:var(--muted); margin-left:.6rem; }
  .complist .sub { display:inline-flex; flex-wrap:wrap; gap:.3rem; margin-left:.5rem; }
</style>
